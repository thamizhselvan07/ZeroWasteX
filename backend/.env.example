# Backend Environment Configuration

# Secret key for JWT token signing (change this in production!)
SECRET_KEY=change-this-secret-in-production

# MongoDB Connection (for production use)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=foodbridge

# Development: Use in-memory storage instead of MongoDB
# Set to 'false' in production to use real MongoDB
USE_MEMORY_STORAGE=true

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Flask Debug Mode (set to 'false' in production)
FLASK_ENV=development
